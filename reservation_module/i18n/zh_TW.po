#. module: reservation_module
#: model:mail.template,body_html:reservation_module.email_template_booking_created
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-family: Arial, Helvetica, sans-serif; color: #333333;\">\n"
"    <!-- Header -->\n"
"    <div style=\"background-color: #f0ad4e; padding: 20px; text-align: center; border-radius: 8px 8px 0 0;\">\n"
"        <h2 style=\"color: #ffffff; margin: 0; font-size: 22px;\">📋 Booking Received</h2>\n"
"    </div>\n"
"\n"
"    <!-- Body -->\n"
"    <div style=\"background-color: #ffffff; border: 1px solid #e0e0e0; border-top: none; padding: 24px; border-radius: 0 0 8px 8px;\">\n"
"        <p style=\"font-size: 15px; margin-top: 0;\">\n"
"            Dear <t t-out=\"object.guest_name\"/>,\n"
"        </p>\n"
"        <p style=\"font-size: 14px;\">\n"
"            Thank you for your booking. Your reservation has been received and is being processed.\n"
"        </p>\n"
"\n"
"        <!-- Booking details card -->\n"
"        <table style=\"width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px;\">\n"
"            <tr>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; width: 40%; color: #666;\">\n"
"                    📋 Booking Reference\n"
"                </td>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; font-weight: bold;\">\n"
"                    <t t-out=\"object.name\"/>\n"
"                </td>\n"
"            </tr>\n"
"            <tr>\n"
"                <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef; color: #666;\">\n"
"                    📊 Status\n"
"                </td>\n"
"                <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef;\">\n"
"                    <span style=\"display: inline-block; padding: 3px 10px; background-color: #ffeeba; color: #856404; border-radius: 4px; font-size: 12px; font-weight: bold;\">Draft / Pending</span>\n"
"                </td>\n"
"            </tr>\n"
"            <tr>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; color: #666;\">\n"
"                    🏷️ Appointment Type\n"
"                </td>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; font-weight: bold;\">\n"
"                    <t t-out=\"object.appointment_type_id.name\"/>\n"
"                </td>\n"
"            </tr>\n"
"            <tr>\n"
"                <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef; color: #666;\">\n"
"                    🗓️ Date &amp; Time\n"
"                </td>\n"
"                <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef;\">\n"
"                    <t t-out=\"object.start_datetime\" t-options=\"{&quot;widget&quot;: &quot;datetime&quot;}\"/> — <t t-out=\"object.end_datetime\" t-options=\"{&quot;widget&quot;: &quot;datetime&quot;}\"/>\n"
"                </td>\n"
"            </tr>\n"
"            <t t-if=\"object.staff_user_id\">\n"
"                <tr>\n"
"                    <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; color: #666;\">\n"
"                        👤 Staff\n"
"                    </td>\n"
"                    <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef;\">\n"
"                        <t t-out=\"object.staff_user_id.name\"/>\n"
"                    </td>\n"
"                </tr>\n"
"            </t>\n"
"            <t t-if=\"object.resource_id\">\n"
"                <tr>\n"
"                    <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef; color: #666;\">\n"
"                        📍 Location / Resource\n"
"                    </td>\n"
"                    <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef;\">\n"
"                        <t t-out=\"object.resource_id.name\"/>\n"
"                    </td>\n"
"                </tr>\n"
"            </t>\n"
"            <tr>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; color: #666;\">\n"
"                    👥 Guests\n"
"                </td>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef;\">\n"
"                    <t t-out=\"object.guest_count\"/>\n"
"                </td>\n"
"            </tr>\n"
"        </table>\n"
"\n"
"        <!-- Payment pending notice -->\n"
"        <t t-if=\"object.payment_status == 'pending'\">\n"
"            <div style=\"margin: 20px 0; padding: 16px; background-color: #fff3cd; border: 1px solid #ffc107; border-radius: 8px;\">\n"
"                <p style=\"margin: 0 0 8px 0; font-size: 15px; font-weight: bold; color: #856404;\">\n"
"                    💳 Payment Required\n"
"                </p>\n"
"                <p style=\"margin: 0 0 12px 0; font-size: 14px; color: #856404;\">\n"
"                    Your booking requires payment before it can be confirmed. Please complete your payment to secure your reservation.\n"
"                </p>\n"
"                <t t-if=\"object.payment_amount\">\n"
"                    <p style=\"margin: 0 0 12px 0; font-size: 16px; font-weight: bold; color: #856404;\">\n"
"                        Amount Due: <t t-out=\"object.payment_amount\" t-options=\"{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: object.currency_id}\"/>\n"
"                    </p>\n"
"                </t>\n"
"                <t t-if=\"object.sale_order_id\">\n"
"                    <div style=\"text-align: center;\">\n"
"                        <a t-attf-href=\"{{ object.sale_order_id.get_portal_url() }}\" style=\"display: inline-block; background-color: #ffc107; color: #212529; padding: 12px 32px; text-decoration: none; border-radius: 6px; font-size: 16px; font-weight: bold;\">\n"
"                            Go to Payment\n"
"                        </a>\n"
"                    </div>\n"
"                </t>\n"
"            </div>\n"
"        </t>\n"
"\n"
"        <!-- No payment required notice -->\n"
"        <t t-if=\"object.payment_status == 'not_required'\">\n"
"            <div style=\"margin: 20px 0; padding: 16px; background-color: #d4edda; border: 1px solid #c3e6cb; border-radius: 8px;\">\n"
"                <p style=\"margin: 0; font-size: 14px; color: #155724;\">\n"
"                    ✓ Your booking is being processed and will be confirmed shortly.\n"
"                </p>\n"
"            </div>\n"
"        </t>\n"
"\n"
"        <!-- View booking link -->\n"
"        <div style=\"text-align: center; margin: 20px 0;\">\n"
"            <a t-att-href=\"object.get_portal_url()\" style=\"display: inline-block; background-color: #875A7B; color: #ffffff; padding: 10px 28px; text-decoration: none; border-radius: 6px; font-size: 14px;\">\n"
"                View Booking Details\n"
"            </a>\n"
"        </div>\n"
