#. module: reservation_module
#: model:mail.template,body_html:reservation_module.email_template_booking_done
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-family: Arial, Helvetica, sans-serif; color: #333333;\">\n"
"    <!-- Header -->\n"
"    <div style=\"background-color: #28a745; padding: 20px; text-align: center; border-radius: 8px 8px 0 0;\">\n"
"        <h2 style=\"color: #ffffff; margin: 0; font-size: 22px;\">✔ Appointment Completed</h2>\n"
"    </div>\n"
"\n"
"    <!-- Body -->\n"
"    <div style=\"background-color: #ffffff; border: 1px solid #e0e0e0; border-top: none; padding: 24px; border-radius: 0 0 8px 8px;\">\n"
"        <p style=\"font-size: 15px; margin-top: 0;\">\n"
"            Dear <t t-out=\"object.guest_name\"/>,\n"
"        </p>\n"
"        <p style=\"font-size: 14px;\">\n"
"            Your appointment has been completed. Thank you for your visit!\n"
"        </p>\n"
"\n"
"        <!-- Booking details card -->\n"
"        <table style=\"width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px;\">\n"
"            <tr>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; width: 40%; color: #666;\">\n"
"                    📋 Booking Reference\n"
"                </td>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; font-weight: bold;\">\n"
"                    <t t-out=\"object.name\"/>\n"
"                </td>\n"
"            </tr>\n"
"            <tr>\n"
"                <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef; color: #666;\">\n"
"                    🏷️ Appointment Type\n"
"                </td>\n"
"                <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef;\">\n"
"                    <t t-out=\"object.appointment_type_id.name\"/>\n"
"                </td>\n"
"            </tr>\n"
"            <tr>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; color: #666;\">\n"
"                    🗓️ Date &amp; Time\n"
"                </td>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef;\">\n"
"                    <t t-out=\"object.start_datetime\" t-options=\"{&quot;widget&quot;: &quot;datetime&quot;}\"/> — <t t-out=\"object.end_datetime\" t-options=\"{&quot;widget&quot;: &quot;datetime&quot;}\"/>\n"
"                </td>\n"
"            </tr>\n"
"            <t t-if=\"object.staff_user_id\">\n"
"                <tr>\n"
"                    <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef; color: #666;\">\n"
"                        👤 Staff\n"
"                    </td>\n"
"                    <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef;\">\n"
"                        <t t-out=\"object.staff_user_id.name\"/>\n"
"                    </td>\n"
"                </tr>\n"
"            </t>\n"
"        </table>\n"
"\n"
"        <!-- Book again -->\n"
"        <div style=\"text-align: center; margin: 24px 0;\">\n"
"            <p style=\"font-size: 14px; color: #555;\">\n"
"                We hope you had a great experience. We'd love to see you again!\n"
"            </p>\n"
"            <a t-att-href=\"'/appointment/' + str(object.appointment_type_id.id)\" style=\"display: inline-block; background-color: #875A7B; color: #ffffff; padding: 10px 28px; text-decoration: none; border-radius: 6px; font-size: 14px;\">\n"
"                Book Again\n"
"            </a>\n"
"        </div>\n"
"\n"
"        <p style=\"font-size: 14px; color: #555; margin-top: 8px;\">\n"
"            Best regards,<br/>\n"
"            <strong><t t-out=\"object.company_id.name\"/></strong>\n"
"        </p>\n"
"    </div>\n"
"</div>\n"
"            "
msgstr ""

#. module: reservation_module
#: model:mail.template,body_html:reservation_module.email_template_booking_confirmed
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-family: Arial, Helvetica, sans-serif; color: #333333;\">\n"
"    <!-- Header -->\n"
"    <div style=\"background-color: #875A7B; padding: 20px; text-align: center; border-radius: 8px 8px 0 0;\">\n"
"        <h2 style=\"color: #ffffff; margin: 0; font-size: 22px;\">✓ Booking Confirmed</h2>\n"
"    </div>\n"
"\n"
"    <!-- Body -->\n"
"    <div style=\"background-color: #ffffff; border: 1px solid #e0e0e0; border-top: none; padding: 24px; border-radius: 0 0 8px 8px;\">\n"
"        <p style=\"font-size: 15px; margin-top: 0;\">\n"
"            Dear <t t-out=\"object.guest_name\"/>,\n"
"        </p>\n"
"        <p style=\"font-size: 14px;\">\n"
"            Your appointment has been confirmed. Here are the details:\n"
"        </p>\n"
"\n"
"        <!-- Booking details card -->\n"
"        <table style=\"width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px;\">\n"
"            <tr>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; width: 40%; color: #666;\">\n"
"                    Booking Reference\n"
"                </td>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; font-weight: bold;\">\n"
"                    <t t-out=\"object.name\"/>\n"
"                </td>\n"
"            </tr>\n"
"            <tr>\n"
"                <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef; color: #666;\">\n"
"                    Status\n"
"                </td>\n"
"                <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef;\">\n"
"                    <span style=\"display: inline-block; padding: 3px 10px; background-color: #d4edda; color: #155724; border-radius: 4px; font-size: 12px; font-weight: bold;\">Confirmed</span>\n"
"                </td>\n"
"            </tr>\n"
"            <tr>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; color: #666;\">\n"
"                    Appointment Type\n"
"                </td>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; font-weight: bold;\">\n"
"                    <t t-out=\"object.appointment_type_id.name\"/>\n"
"                </td>\n"
"            </tr>\n"
"            <tr>\n"
"                <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef; color: #666;\">\n"
"                    Date &amp; Time\n"
"                </td>\n"
"                <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef;\">\n"
"                    <t t-out=\"object.start_datetime\" t-options=\"{&quot;widget&quot;: &quot;datetime&quot;}\"/> — <t t-out=\"object.end_datetime\" t-options=\"{&quot;widget&quot;: &quot;datetime&quot;}\"/>\n"
"                </td>\n"
"            </tr>\n"
"            <t t-if=\"object.staff_user_id\">\n"
"                <tr>\n"
"                    <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; color: #666;\">\n"
"                        Staff\n"
"                    </td>\n"
"                    <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef;\">\n"
"                        <t t-out=\"object.staff_user_id.name\"/>\n"
"                    </td>\n"
"                </tr>\n"
"            </t>\n"
"            <t t-if=\"object.resource_id\">\n"
"                <tr>\n"
"                    <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef; color: #666;\">\n"
"                        Location / Resource\n"
"                    </td>\n"
"                    <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef;\">\n"
"                        <t t-out=\"object.resource_id.name\"/>\n"
"                    </td>\n"
"                </tr>\n"
"            </t>\n"
"            <tr>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; color: #666;\">\n"
"                    Guests\n"
"                </td>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef;\">\n"
"                    <t t-out=\"object.guest_count\"/>\n"
"                </td>\n"
"            </tr>\n"
"        </table>\n"
"\n"
"        <!-- Meeting URL button -->\n"
"        <t t-if=\"object.meeting_url\">\n"
"            <div style=\"text-align: center; margin: 24px 0; padding: 20px; background-color: #f0faf0; border: 1px solid #c3e6c3; border-radius: 8px;\">\n"
"                <p style=\"margin: 0 0 12px 0; font-size: 14px; color: #555;\">\n"
"                    This is an online meeting. Use the link below to join at the scheduled time:\n"
"                </p>\n"
"                <a t-att-href=\"object.meeting_url\" style=\"display: inline-block; background-color: #28a745; color: #ffffff; padding: 12px 32px; text-decoration: none; border-radius: 6px; font-size: 16px; font-weight: bold;\">\n"
"                    Join Meeting\n"
"                </a>\n"
"                <p style=\"margin: 12px 0 0 0; font-size: 12px; color: #888;\">\n"
"                    <t t-out=\"object.meeting_url\"/>\n"
"                </p>\n"
"            </div>\n"
"        </t>\n"
"\n"
"        <!-- View booking link -->\n"
"        <div style=\"text-align: center; margin: 20px 0;\">\n"
"            <a t-att-href=\"object.get_portal_url()\" style=\"display: inline-block; background-color: #875A7B; color: #ffffff; padding: 10px 28px; text-decoration: none; border-radius: 6px; font-size: 14px;\">\n"
"                View Booking Details\n"
"            </a>\n"
"        </div>\n"
"\n"
"        <p style=\"font-size: 14px; color: #555; margin-bottom: 0;\">\n"
"            Thank you for your booking!\n"
"        </p>\n"
"        <p style=\"font-size: 14px; color: #555; margin-top: 8px;\">\n"
"            Best regards,<br/>\n"
"            <strong><t t-out=\"object.company_id.name\"/></strong>\n"
"        </p>\n"
"    </div>\n"
"</div>\n"
"            "
msgstr ""

