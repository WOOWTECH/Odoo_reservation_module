<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Sale Order Form: Add Booking Smart Button -->
    <record id="sale_order_view_form_booking" model="ir.ui.view">
        <field name="name">sale.order.form.booking</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" type="object" name="action_view_bookings"
                        icon="fa-calendar" invisible="booking_count == 0">
                    <field name="booking_count" widget="statinfo" string="Bookings"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
