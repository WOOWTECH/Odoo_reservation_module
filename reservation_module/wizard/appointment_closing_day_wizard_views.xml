<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Wizard Form View -->
    <record id="appointment_closing_day_wizard_form" model="ir.ui.view">
        <field name="name">appointment.closing.day.wizard.form</field>
        <field name="model">appointment.closing.day.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Closing Days">
                <group>
                    <field name="appointment_type_id" invisible="1"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="reason" placeholder="e.g. National Holiday, Maintenance..."/>
                </group>
                <footer>
                    <button name="action_confirm" string="Add Closing Days" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Closing Day List View (embedded in appointment type form) -->
    <record id="appointment_closing_day_list" model="ir.ui.view">
        <field name="name">appointment.closing.day.list</field>
        <field name="model">appointment.closing.day</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="date"/>
                <field name="name" string="Reason"/>
            </list>
        </field>
    </record>

</odoo>
