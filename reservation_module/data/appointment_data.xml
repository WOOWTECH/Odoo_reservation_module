<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequences -->
        <record id="sequence_appointment_booking" model="ir.sequence">
            <field name="name">Appointment Booking</field>
            <field name="code">appointment.booking</field>
            <field name="prefix">APT</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="sequence_appointment_booking_token" model="ir.sequence">
            <field name="name">Appointment Booking Token</field>
            <field name="code">appointment.booking.token</field>
            <field name="implementation">no_gap</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Email Templates -->
        <record id="email_template_booking_confirmed" model="mail.template">
            <field name="name">Appointment: Booking Confirmed</field>
            <field name="model_id" ref="model_appointment_booking"/>
            <field name="email_from">{{ (object.company_id.email or user.email_formatted) }}</field>
            <field name="email_to">{{ object.guest_email }}</field>
            <field name="subject">Your appointment has been confirmed - {{ object.name }}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px; font-family: Arial, Helvetica, sans-serif; color: #333333;">
    <!-- Header -->
    <div style="background-color: #875A7B; padding: 20px; text-align: center; border-radius: 8px 8px 0 0;">
        <h2 style="color: #ffffff; margin: 0; font-size: 22px;">✓ Booking Confirmed</h2>
    </div>

    <!-- Body -->
    <div style="background-color: #ffffff; border: 1px solid #e0e0e0; border-top: none; padding: 24px; border-radius: 0 0 8px 8px;">
        <p style="font-size: 15px; margin-top: 0;">
            Dear <t t-out="object.guest_name"/>,
        </p>
        <p style="font-size: 14px;">
            Your appointment has been confirmed. Here are the details:
        </p>

        <!-- Booking details card -->
        <table style="width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px;">
            <tr>
                <td style="padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; width: 40%; color: #666;">
                    📋 Booking Reference
                </td>
                <td style="padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; font-weight: bold;">
                    <t t-out="object.name"/>
                </td>
            </tr>
            <tr>
                <td style="padding: 10px 12px; border-bottom: 1px solid #e9ecef; color: #666;">
                    🏷️ Appointment Type
                </td>
                <td style="padding: 10px 12px; border-bottom: 1px solid #e9ecef; font-weight: bold;">
                    <t t-out="object.appointment_type_id.name"/>
                </td>
            </tr>
            <tr>
                <td style="padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; color: #666;">
                    🗓️ Date &amp; Time
                </td>
                <td style="padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef;">
                    <t t-out="object.start_datetime" t-options='{"widget": "datetime"}'/> — <t t-out="object.end_datetime" t-options='{"widget": "datetime"}'/>
                </td>
            </tr>
            <t t-if="object.staff_user_id">
                <tr>
                    <td style="padding: 10px 12px; border-bottom: 1px solid #e9ecef; color: #666;">
                        👤 Staff
                    </td>
                    <td style="padding: 10px 12px; border-bottom: 1px solid #e9ecef;">
                        <t t-out="object.staff_user_id.name"/>
                    </td>
                </tr>
            </t>
            <t t-if="object.resource_id">
                <tr>
                    <td style="padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; color: #666;">
                        📍 Location / Resource
                    </td>
                    <td style="padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef;">
                        <t t-out="object.resource_id.name"/>
                    </td>
                </tr>
            </t>
            <tr>
                <td style="padding: 10px 12px; border-bottom: 1px solid #e9ecef; color: #666;">
                    👥 Guests
                </td>
                <td style="padding: 10px 12px; border-bottom: 1px solid #e9ecef;">
                    <t t-out="object.guest_count"/>
                </td>
            </tr>
        </table>

        <!-- Meeting URL button -->
        <t t-if="object.meeting_url">
            <div style="text-align: center; margin: 24px 0; padding: 20px; background-color: #f0faf0; border: 1px solid #c3e6c3; border-radius: 8px;">
                <p style="margin: 0 0 12px 0; font-size: 14px; color: #555;">
                    🎥 This is an online meeting. Use the link below to join at the scheduled time:
                </p>
                <a t-att-href="object.meeting_url"
                   style="display: inline-block; background-color: #28a745; color: #ffffff; padding: 12px 32px; text-decoration: none; border-radius: 6px; font-size: 16px; font-weight: bold;">
                    Join Meeting
                </a>
                <p style="margin: 12px 0 0 0; font-size: 12px; color: #888;">
                    <t t-out="object.meeting_url"/>
                </p>
            </div>
        </t>

        <!-- View booking link -->
        <div style="text-align: center; margin: 20px 0;">
            <a t-att-href="object.get_portal_url()"
               style="display: inline-block; background-color: #875A7B; color: #ffffff; padding: 10px 28px; text-decoration: none; border-radius: 6px; font-size: 14px;">
                View Booking Details
            </a>
        </div>

        <p style="font-size: 14px; color: #555; margin-bottom: 0;">
            Thank you for your booking!
        </p>
        <p style="font-size: 14px; color: #555; margin-top: 8px;">
            Best regards,<br/>
            <strong><t t-out="object.company_id.name"/></strong>
        </p>
    </div>
</div>
            </field>
        </record>

        <record id="email_template_booking_cancelled" model="mail.template">
            <field name="name">Appointment: Booking Cancelled</field>
            <field name="model_id" ref="model_appointment_booking"/>
            <field name="email_from">{{ (object.company_id.email or user.email_formatted) }}</field>
            <field name="email_to">{{ object.guest_email }}</field>
            <field name="subject">Your appointment has been cancelled - {{ object.name }}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px; font-family: Arial, Helvetica, sans-serif; color: #333333;">
    <!-- Header -->
    <div style="background-color: #dc3545; padding: 20px; text-align: center; border-radius: 8px 8px 0 0;">
        <h2 style="color: #ffffff; margin: 0; font-size: 22px;">Booking Cancelled</h2>
    </div>

    <!-- Body -->
    <div style="background-color: #ffffff; border: 1px solid #e0e0e0; border-top: none; padding: 24px; border-radius: 0 0 8px 8px;">
        <p style="font-size: 15px; margin-top: 0;">
            Dear <t t-out="object.guest_name"/>,
        </p>
        <p style="font-size: 14px;">
            Your appointment has been cancelled. Here were the details:
        </p>

        <!-- Booking details card -->
        <table style="width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px;">
            <tr>
                <td style="padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; width: 40%; color: #666;">
                    📋 Booking Reference
                </td>
                <td style="padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; font-weight: bold;">
                    <t t-out="object.name"/>
                </td>
            </tr>
            <tr>
                <td style="padding: 10px 12px; border-bottom: 1px solid #e9ecef; color: #666;">
                    🏷️ Appointment Type
                </td>
                <td style="padding: 10px 12px; border-bottom: 1px solid #e9ecef;">
                    <t t-out="object.appointment_type_id.name"/>
                </td>
            </tr>
            <tr>
                <td style="padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; color: #666;">
                    🗓️ Date &amp; Time
                </td>
                <td style="padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef;">
                    <t t-out="object.start_datetime" t-options='{"widget": "datetime"}'/> — <t t-out="object.end_datetime" t-options='{"widget": "datetime"}'/>
                </td>
            </tr>
        </table>

        <!-- Book again button -->
        <div style="text-align: center; margin: 24px 0;">
            <p style="font-size: 14px; color: #555;">
                If you wish to make a new appointment:
            </p>
            <a t-att-href="'/appointment/' + str(object.appointment_type_id.id)"
               style="display: inline-block; background-color: #875A7B; color: #ffffff; padding: 10px 28px; text-decoration: none; border-radius: 6px; font-size: 14px;">
                Book Again
            </a>
        </div>

        <p style="font-size: 14px; color: #555; margin-top: 8px;">
            Best regards,<br/>
            <strong><t t-out="object.company_id.name"/></strong>
        </p>
    </div>
</div>
            </field>
        </record>

        <record id="email_template_booking_reminder" model="mail.template">
            <field name="name">Appointment: Booking Reminder</field>
            <field name="model_id" ref="model_appointment_booking"/>
            <field name="email_from">{{ (object.company_id.email or user.email_formatted) }}</field>
            <field name="email_to">{{ object.guest_email }}</field>
            <field name="subject">Reminder: Your appointment is coming up - {{ object.name }}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px; font-family: Arial, Helvetica, sans-serif; color: #333333;">
    <!-- Header -->
    <div style="background-color: #17a2b8; padding: 20px; text-align: center; border-radius: 8px 8px 0 0;">
        <h2 style="color: #ffffff; margin: 0; font-size: 22px;">⏰ Appointment Reminder</h2>
