#. module: reservation_module
#: model:mail.template,body_html:reservation_module.email_template_payment_failure
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-family: Arial, Helvetica, sans-serif; color: #333333;\">\n"
"    <div style=\"background-color: #dc3545; padding: 20px; text-align: center; border-radius: 8px 8px 0 0;\">\n"
"        <h2 style=\"color: #ffffff; margin: 0; font-size: 22px;\">Payment Failed</h2>\n"
"    </div>\n"
"    <div style=\"background-color: #ffffff; border: 1px solid #e0e0e0; border-top: none; padding: 24px; border-radius: 0 0 8px 8px;\">\n"
"        <p style=\"font-size: 15px; margin-top: 0;\">\n"
"            Dear <t t-out=\"object.guest_name\"/>,\n"
"        </p>\n"
"        <p style=\"font-size: 14px;\">\n"
"            We were unable to process the payment for your booking. Your reservation is still pending.\n"
"        </p>\n"
"        <table style=\"width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px;\">\n"
"            <tr>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; width: 40%; color: #666;\">\n"
"                    Booking Reference\n"
"                </td>\n"
"                <td style=\"padding: 10px 12px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; font-weight: bold;\">\n"
"                    <t t-out=\"object.name\"/>\n"
"                </td>\n"
"            </tr>\n"
"            <tr>\n"
"                <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef; color: #666;\">\n"
"                    Amount Due\n"
"                </td>\n"
"                <td style=\"padding: 10px 12px; border-bottom: 1px solid #e9ecef; font-weight: bold;\">\n"
"                    <t t-out=\"object.payment_amount\" t-options=\"{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: object.currency_id}\"/>\n"
"                </td>\n"
"            </tr>\n"
"        </table>\n"
"        <div style=\"text-align: center; margin: 24px 0;\">\n"
"            <p style=\"font-size: 14px; color: #555;\">Please try again using the link below:</p>\n"
"            <t t-if=\"object.sale_order_id\">\n"
"                <a t-attf-href=\"{{ object.sale_order_id.get_portal_url() }}\" style=\"display: inline-block; background-color: #007bff; color: #ffffff; padding: 12px 32px; text-decoration: none; border-radius: 6px; font-size: 16px; font-weight: bold;\">\n"
"                    Retry Payment\n"
"                </a>\n"
"            </t>\n"
"            <t t-else=\"\">\n"
"                <a t-att-href=\"object.get_portal_url()\" style=\"display: inline-block; background-color: #007bff; color: #ffffff; padding: 12px 32px; text-decoration: none; border-radius: 6px; font-size: 16px; font-weight: bold;\">\n"
"                    View Booking\n"
"                </a>\n"
"            </t>\n"
"        </div>\n"
"        <p style=\"font-size: 14px; color: #555;\">\n"
"            If you continue to experience issues, please contact us for assistance.\n"
"        </p>\n"
"        <p style=\"font-size: 14px; color: #555; margin-top: 8px;\">\n"
"            Best regards,<br/>\n"
"            <strong><t t-out=\"object.company_id.name\"/></strong>\n"
"        </p>\n"
"    </div>\n"
"</div>\n"
"            "
msgstr ""

#. module: reservation_module
#: model:mail.template,body_html:reservation_module.email_template_booking_reminder
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"    <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"        Dear <t t-out=\"object.guest_name\"/>,\n"
"        <br/><br/>\n"
"        This is a friendly reminder about your upcoming appointment:\n"
"        <br/><br/>\n"
"        <strong>Appointment Type:</strong> <t t-out=\"object.appointment_type_id.name\"/><br/>\n"
"        <strong>Date &amp; Time:</strong> <t t-out=\"object.start_datetime\" t-options=\"{&quot;widget&quot;: &quot;datetime&quot;}\"/> - <t t-out=\"object.end_datetime\" t-options=\"{&quot;widget&quot;: &quot;datetime&quot;}\"/><br/>\n"
"        <t t-if=\"object.resource_id\">\n"
"            <strong>Resource:</strong> <t t-out=\"object.resource_id.name\"/><br/>\n"
"        </t>\n"
"        <t t-if=\"object.staff_user_id\">\n"
"            <strong>Staff:</strong> <t t-out=\"object.staff_user_id.name\"/><br/>\n"
"        </t>\n"
"        <br/>\n"
"        <strong>Booking Reference:</strong> <t t-out=\"object.name\"/><br/>\n"
"        <br/>\n"
"        You can view your booking here:<br/>\n"
"        <a t-att-href=\"object.get_portal_url()\">View Booking</a>\n"
"        <br/><br/>\n"
"        We look forward to seeing you!\n"
"        <br/><br/>\n"
"        Best regards,<br/>\n"
"        <t t-out=\"object.company_id.name\"/>\n"
"    </p>\n"
"</div>\n"
"            "
msgstr ""

