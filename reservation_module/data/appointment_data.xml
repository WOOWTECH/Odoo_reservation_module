                    </td>
                    <td style="padding: 10px 12px; border-bottom: 1px solid #e9ecef;">
                        <t t-out="object.staff_user_id.name"/>
                    </td>
                </tr>
            </t>
        </table>

        <!-- Book again -->
        <div style="text-align: center; margin: 24px 0;">
            <p style="font-size: 14px; color: #555;">
                We hope you had a great experience. We'd love to see you again!
            </p>
            <a t-att-href="'/appointment/' + str(object.appointment_type_id.id)"
               style="display: inline-block; background-color: #875A7B; color: #ffffff; padding: 10px 28px; text-decoration: none; border-radius: 6px; font-size: 14px;">
                Book Again
            </a>
        </div>

        <p style="font-size: 14px; color: #555; margin-top: 8px;">
            Best regards,<br/>
            <strong><t t-out="object.company_id.name"/></strong>
        </p>
    </div>
</div>
            </field>
        </record>
    </data>
</odoo>
