<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Portal Home: "My Bookings" card                              -->
    <!-- ============================================================ -->
    <template id="portal_my_home_booking"
              name="My Bookings"
              customize_show="True"
              inherit_id="portal.portal_my_home"
              priority="25">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_client_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/reservation_module/static/src/img/booking.svg'"/>
                <t t-set="title">My Bookings</t>
                <t t-set="url" t-value="'/my/ext-bookings'"/>
                <t t-set="text">View and manage your appointments</t>
                <t t-set="placeholder_count" t-value="'booking_count'"/>
            </t>
        </div>
    </template>

    <!-- ============================================================ -->
    <!-- Portal Breadcrumbs                                            -->
    <!-- ============================================================ -->
    <template id="portal_my_home_menu_booking"
              name="Portal layout: booking menu entries"
              inherit_id="portal.portal_breadcrumbs"
              priority="40">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'ext_bookings'"
                class="breadcrumb-item active">
                My Bookings
            </li>
            <li t-if="page_name == 'ext_booking_detail'"
                t-attf-class="breadcrumb-item">
                <a href="/my/ext-bookings">My Bookings</a>
            </li>
            <li t-if="page_name == 'ext_booking_detail' and booking"
                class="breadcrumb-item active">
                <t t-out="booking.name"/>
            </li>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Portal: Booking List Page (/my/bookings)                     -->
    <!-- ============================================================ -->
    <template id="portal_my_bookings" name="My Bookings">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">My Bookings</t>
            </t>

            <t t-if="not bookings">
                <div class="alert alert-warning" role="alert">
                    There are no bookings yet.
                    <a href="/appointment" class="alert-link">Book Now</a>
                </div>
            </t>

            <t t-if="bookings">
                <t t-call="portal.portal_table">
                    <thead>
                        <tr>
                            <th class="text-start">#</th>
                            <th>Booking Ref</th>
                            <th>Appointment Type</th>
                            <th>Date &amp; Time</th>
                            <th class="text-end">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="bookings" t-as="bk">
                            <tr>
                                <td class="text-start">
                                    <a t-attf-href="/my/ext-bookings/#{bk.id}">
                                        #<span t-out="bk.id"/>
                                    </a>
                                </td>
                                <td>
                                    <a t-attf-href="/my/ext-bookings/#{bk.id}">
                                        <span t-out="bk.name"/>
                                    </a>
                                </td>
                                <td>
                                    <span t-out="bk.appointment_type_id.name"/>
                                </td>
                                <td>
                                    <span t-field="bk.start_datetime" t-options='{"widget": "datetime", "format": "yyyy-MM-dd HH:mm"}'/>
                                </td>
                                <td class="text-end">
                                    <span t-if="bk.state == 'confirmed'"
                                          class="badge rounded-pill text-bg-success">
                                        Confirmed
                                    </span>
                                    <span t-if="bk.state == 'done'"
                                          class="badge rounded-pill text-bg-info">
                                        Completed
                                    </span>
                                    <span t-if="bk.state == 'cancelled'"
                                          class="badge rounded-pill text-bg-danger">
                                        Cancelled
                                    </span>
                                    <span t-if="bk.state == 'pending_payment'"
                                          class="badge rounded-pill text-bg-warning">
                                        Pending Payment
                                    </span>
                                    <span t-if="bk.state == 'draft'"
                                          class="badge rounded-pill text-bg-secondary">
                                        Draft
                                    </span>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </t>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Portal: Booking Detail Page (/my/bookings/<id>)              -->
    <!-- ============================================================ -->
    <template id="portal_my_booking_detail" name="My Booking Detail"
              inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <t t-set="o_portal_fullwidth_alert" groups="base.group_user">
                <t t-call="portal.portal_back_in_edit_mode">
                    <t t-set="backend_url"
                       t-value="'/odoo/appointments/bookings/%s' % booking.id"/>
                </t>
            </t>

            <div class="row o_portal_booking_sidebar">
                <!-- ─── Sidebar ─── -->
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-4 col-xxl-3 d-print-none'"/>

                    <t t-set="entries">
                        <div class="d-flex flex-wrap flex-column gap-4">
                            <!-- Sidebar Navigation -->
                            <div class="d-flex align-items-center flex-grow-1 p-0" t-ignore="true" role="complementary">
                                <ul class="nav flex-column">
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#card_header">
                                            Booking
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#booking_chat">
                                            History
                                        </a>
                                    </li>
                                </ul>
                            </div>

                            <!-- Status -->
                            <div class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">Status</small></h6>
                                <span t-if="booking.state == 'confirmed'"
                                      class="badge rounded-pill text-bg-success">
                                    Confirmed
                                </span>
                                <span t-if="booking.state == 'done'"
                                      class="badge rounded-pill text-bg-info">
                                    Completed
                                </span>
                                <span t-if="booking.state == 'cancelled'"
                                      class="badge rounded-pill text-bg-danger">
                                    Cancelled
                                </span>
                                <span t-if="booking.state == 'pending_payment'"
                                      class="badge rounded-pill text-bg-warning">
                                    Pending Payment
                                </span>
                                <span t-if="booking.state == 'draft'"
                                      class="badge rounded-pill text-bg-secondary">
                                    Draft
                                </span>
                            </div>

                            <!-- Meeting Link -->
                            <div t-if="booking.meeting_url and booking.state in ('draft', 'pending_payment', 'confirmed')"
                                 class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">Meeting</small></h6>
                                <a t-att-href="booking.meeting_url" target="_blank"
                                   class="btn btn-light btn-sm">
                                    <i class="fa fa-video-camera me-1"/>
                                    <t t-if="booking.discuss_channel_id">Open Meeting Room</t>
                                    <t t-else="">Join Meeting</t>
                                </a>
                            </div>

                            <!-- Payment -->
                            <div t-if="booking.payment_status == 'paid'"
                                 class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">Payment</small></h6>
                                <span class="text-success">
                                    <i class="fa fa-check-circle me-1"/>Paid
                                </span>
                            </div>
                            <div t-if="booking.payment_status == 'pending' and booking.sale_order_id"
                                 class="d-flex flex-column gap-2">
                                <h6><small class="text-muted">Payment</small></h6>
                                <a t-attf-href="/my/orders/#{booking.sale_order_id.id}?access_token=#{booking.sale_order_id.access_token}"
                                   class="btn btn-warning btn-sm">
                                    <i class="fa fa-credit-card me-1"/>Go to Payment
                                </a>
                            </div>

                            <!-- Cancel Action -->
                            <div t-if="booking.state in ('draft', 'pending_payment', 'confirmed')"
                                 class="d-flex flex-column gap-2">
                                <form t-attf-action="/my/ext-bookings/#{booking.id}/cancel" method="POST" class="d-inline">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <button type="submit" class="btn btn-outline-danger btn-sm w-100"
                                            onclick="return confirm('Are you sure you want to cancel this booking?');">
                                        <i class="fa fa-times me-1"/>Cancel Booking
                                    </button>
                                </form>
                            </div>
                        </div>
                    </t>
                </t>

                <!-- ─── Main Content ─── -->
                <div id="booking_content" class="o_portal_content col-12 col-lg-8 col-xxl-9">
                    <div id="card">
                        <div id="card_header" data-anchor="true">
                            <div class="row justify-content-between mb-3">
                                <div class="col-12 col-md-9">
                                    <h3 class="my-0">
                                        <i class="fa fa-calendar me-1"/>
                                        <span t-out="booking.name"/>
                                        <small class="text-muted d-none d-md-inline">(#<span t-out="booking.id"/>)</small>
                                    </h3>
                                </div>
                                <div class="col-auto">
                                    <small class="text-end">Status:</small>
                                    <span t-if="booking.state == 'confirmed'" class="badge rounded-pill text-bg-success">Confirmed</span>
                                    <span t-if="booking.state == 'done'" class="badge rounded-pill text-bg-info">Completed</span>
                                    <span t-if="booking.state == 'cancelled'" class="badge rounded-pill text-bg-danger">Cancelled</span>
                                    <span t-if="booking.state == 'pending_payment'" class="badge rounded-pill text-bg-warning">Pending Payment</span>
                                    <span t-if="booking.state == 'draft'" class="badge rounded-pill text-bg-secondary">Draft</span>
                                </div>
                            </div>
                        </div>

                        <div id="card_body">
                            <div class="row mb-4">
                                <div class="col-12 col-md-6">
                                    <div><strong>Appointment:</strong> <span t-out="booking.appointment_type_id.name"/></div>
                                    <div>
                                        <strong>Date &amp; Time:</strong>
                                        <span t-field="booking.start_datetime"/> -
                                        <span t-field="booking.end_datetime" t-options="{'time_only': True}"/>
                                    </div>
                                    <div><strong>Guests:</strong> <span t-out="booking.guest_count"/></div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div t-if="booking.staff_user_id">
                                        <strong>Staff:</strong> <span t-out="booking.staff_user_id.name"/>
                                    </div>
                                    <div t-if="booking.resource_id">
                                        <strong>Location:</strong> <span t-out="booking.resource_id.name"/>
                                    </div>
                                </div>
                            </div>

                            <div t-if="booking.notes" class="mb-4">
                                <h5 class="mb-1">Notes</h5>
                                <hr class="mt-1 mb-2"/>
                                <div class="py-1 px-2 bg-100 small" t-out="booking.notes"/>
                            </div>

                            <!-- Meeting info for online meetings -->
                            <div t-if="booking.meeting_url and booking.state in ('draft', 'pending_payment', 'confirmed')"
                                 class="mb-4">
                                <h5 class="mb-1">Online Meeting</h5>
                                <hr class="mt-1 mb-2"/>
                                <p class="text-muted small">
                                    <i class="fa fa-video-camera me-1"/>
                                    <t t-if="booking.discuss_channel_id">
                                        This is an online meeting. Open the meeting room below to chat and start a video call:
                                    </t>
                                    <t t-else="">
                                        This is an online meeting. Use the link below to join at the scheduled time:
                                    </t>
                                </p>
                                <a t-att-href="booking.meeting_url" target="_blank"
                                   class="btn btn-light btn-sm">
                                    <i class="fa fa-video-camera me-1"/>
                                    <t t-if="booking.discuss_channel_id">Open Meeting Room</t>
                                    <t t-else="">Join Meeting</t>
                                </a>
                                <p class="mt-2 small text-muted">
                                    <t t-out="booking.meeting_url"/>
                                </p>
                            </div>
                        </div>
                    </div>

                    <hr/>
                    <!-- Communication history / Chatter -->
                    <div id="booking_chat" data-anchor="true">
                        <h3>Communication history</h3>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="booking"/>
                            <t t-set="token" t-value="token"/>
                            <t t-set="allow_composer" t-value="allow_composer"/>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

</odoo>
