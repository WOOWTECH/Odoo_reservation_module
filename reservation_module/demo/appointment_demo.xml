<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Demo Resources -->
        <record id="resource_meeting_room_a" model="resource.resource">
            <field name="name">Meeting Room A</field>
            <field name="resource_type">material</field>
            <field name="capacity">10</field>
            <field name="icon">fa-building</field>
        </record>

        <record id="resource_meeting_room_b" model="resource.resource">
            <field name="name">Meeting Room B</field>
            <field name="resource_type">material</field>
            <field name="capacity">6</field>
            <field name="icon">fa-building</field>
        </record>

        <record id="resource_table_1" model="resource.resource">
            <field name="name">Table 1 - Window</field>
            <field name="resource_type">material</field>
            <field name="capacity">4</field>
            <field name="icon">fa-cutlery</field>
        </record>

        <record id="resource_table_2" model="resource.resource">
            <field name="name">Table 2 - Garden View</field>
            <field name="resource_type">material</field>
            <field name="capacity">6</field>
            <field name="icon">fa-cutlery</field>
        </record>

        <record id="resource_table_3" model="resource.resource">
            <field name="name">Table 3 - Private Room</field>
            <field name="resource_type">material</field>
            <field name="capacity">8</field>
            <field name="icon">fa-cutlery</field>
        </record>

        <record id="resource_tennis_court" model="resource.resource">
            <field name="name">Tennis Court</field>
            <field name="resource_type">material</field>
            <field name="capacity">4</field>
            <field name="icon">fa-futbol-o</field>
        </record>

        <!-- Appointment Type: Meeting -->
        <record id="appointment_type_meeting" model="appointment.type">
            <field name="name">Business Meeting</field>
            <field name="description"><![CDATA[
                <p>Schedule a business meeting with our team, suitable for:</p>
                <ul>
                    <li>Project discussions</li>
                    <li>Client consultations</li>
                    <li>Strategic planning</li>
                </ul>
            ]]></field>
            <field name="slot_duration">1.0</field>
            <field name="slot_interval">1.0</field>
            <field name="max_booking_days">30</field>
            <field name="min_booking_hours">2.0</field>
            <field name="cancel_before_hours">24.0</field>
            <field name="location_type">physical</field>
            <field name="assign_staff" eval="True"/>
            <field name="allow_customer_choose_staff" eval="True"/>
            <field name="auto_confirm" eval="True"/>
            <field name="is_published" eval="True"/>
            <field name="icon">fa-handshake-o</field>
            <field name="staff_user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- Availability for Meeting -->
        <record id="availability_meeting_mon" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_meeting"/>
            <field name="dayofweek">0</field>
            <field name="hour_from">9.0</field>
            <field name="hour_to">17.0</field>
        </record>
        <record id="availability_meeting_tue" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_meeting"/>
            <field name="dayofweek">1</field>
            <field name="hour_from">9.0</field>
            <field name="hour_to">17.0</field>
        </record>
        <record id="availability_meeting_wed" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_meeting"/>
            <field name="dayofweek">2</field>
            <field name="hour_from">9.0</field>
            <field name="hour_to">17.0</field>
        </record>
        <record id="availability_meeting_thu" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_meeting"/>
            <field name="dayofweek">3</field>
            <field name="hour_from">9.0</field>
            <field name="hour_to">17.0</field>
        </record>
        <record id="availability_meeting_fri" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_meeting"/>
            <field name="dayofweek">4</field>
            <field name="hour_from">9.0</field>
            <field name="hour_to">17.0</field>
        </record>

        <!-- Appointment Type: Video Call -->
        <record id="appointment_type_video_call" model="appointment.type">
            <field name="name">Video Consultation</field>
            <field name="description"><![CDATA[
                <p>Schedule a video consultation from anywhere in the world.</p>
                <p>After booking, our team will send you a meeting link.</p>
            ]]></field>
            <field name="slot_duration">0.5</field>
            <field name="slot_interval">0.5</field>
            <field name="max_booking_days">14</field>
            <field name="min_booking_hours">1.0</field>
            <field name="cancel_before_hours">2.0</field>
            <field name="location_type">online</field>
            <field name="assign_staff" eval="True"/>
            <field name="allow_customer_choose_staff" eval="True"/>
            <field name="auto_confirm" eval="True"/>
            <field name="is_published" eval="True"/>
            <field name="icon">fa-video-camera</field>
            <field name="staff_user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- Availability for Video Call -->
        <record id="availability_video_mon" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_video_call"/>
            <field name="dayofweek">0</field>
            <field name="hour_from">10.0</field>
            <field name="hour_to">18.0</field>
        </record>
        <record id="availability_video_wed" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_video_call"/>
            <field name="dayofweek">2</field>
            <field name="hour_from">10.0</field>
            <field name="hour_to">18.0</field>
        </record>
        <record id="availability_video_fri" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_video_call"/>
            <field name="dayofweek">4</field>
            <field name="hour_from">10.0</field>
            <field name="hour_to">18.0</field>
        </record>

        <!-- Appointment Type: Table Booking -->
        <record id="appointment_type_table" model="appointment.type">
            <field name="name">Restaurant Reservation</field>
            <field name="description"><![CDATA[
                <p>Reserve a table at our restaurant.</p>
                <ul>
                    <li>Indoor and outdoor seating available</li>
                    <li>Private room options</li>
                    <li>Special occasion arrangements</li>
                </ul>
            ]]></field>
            <field name="slot_duration">2.0</field>
            <field name="slot_interval">0.5</field>
            <field name="max_booking_days">60</field>
            <field name="min_booking_hours">4.0</field>
            <field name="cancel_before_hours">4.0</field>
            <field name="location_type">physical</field>
            <field name="assign_location" eval="True"/>
            <field name="allow_customer_choose_location" eval="True"/>
            <field name="manage_capacity" eval="True"/>
            <field name="auto_confirm" eval="True"/>
            <field name="is_published" eval="True"/>
            <field name="icon">fa-cutlery</field>
            <field name="resource_ids" eval="[(4, ref('resource_table_1')), (4, ref('resource_table_2')), (4, ref('resource_table_3'))]"/>
        </record>

        <!-- Availability for Table (dinner hours) -->
        <record id="availability_table_mon" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_table"/>
            <field name="dayofweek">0</field>
            <field name="hour_from">18.0</field>
            <field name="hour_to">22.0</field>
        </record>
        <record id="availability_table_tue" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_table"/>
            <field name="dayofweek">1</field>
            <field name="hour_from">18.0</field>
            <field name="hour_to">22.0</field>
        </record>
        <record id="availability_table_wed" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_table"/>
            <field name="dayofweek">2</field>
            <field name="hour_from">18.0</field>
            <field name="hour_to">22.0</field>
        </record>
        <record id="availability_table_thu" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_table"/>
            <field name="dayofweek">3</field>
            <field name="hour_from">18.0</field>
            <field name="hour_to">22.0</field>
        </record>
        <record id="availability_table_fri" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_table"/>
            <field name="dayofweek">4</field>
            <field name="hour_from">18.0</field>
            <field name="hour_to">23.0</field>
        </record>
        <record id="availability_table_sat" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_table"/>
            <field name="dayofweek">5</field>
            <field name="hour_from">12.0</field>
            <field name="hour_to">23.0</field>
        </record>
        <record id="availability_table_sun" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_table"/>
            <field name="dayofweek">6</field>
            <field name="hour_from">12.0</field>
            <field name="hour_to">21.0</field>
        </record>

        <!-- Appointment Type: Resource Booking (Tennis Court) -->
        <record id="appointment_type_tennis" model="appointment.type">
            <field name="name">Tennis Court Booking</field>
            <field name="description"><![CDATA[
                <p>Book our professional tennis court.</p>
                <ul>
                    <li>Clay court surface</li>
                    <li>Night lighting available</li>
                    <li>Equipment rental available</li>
                </ul>
            ]]></field>
            <field name="slot_duration">1.0</field>
            <field name="slot_interval">1.0</field>
            <field name="max_booking_days">7</field>
            <field name="min_booking_hours">2.0</field>
            <field name="cancel_before_hours">4.0</field>
            <field name="location_type">physical</field>
            <field name="assign_location" eval="True"/>
            <field name="allow_customer_choose_location" eval="True"/>
            <field name="auto_confirm" eval="True"/>
            <field name="is_published" eval="True"/>
            <field name="icon">fa-futbol-o</field>
            <field name="resource_ids" eval="[(4, ref('resource_tennis_court'))]"/>
        </record>

        <!-- Availability for Tennis Court -->
        <record id="availability_tennis_mon" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_tennis"/>
            <field name="dayofweek">0</field>
            <field name="hour_from">7.0</field>
            <field name="hour_to">21.0</field>
        </record>
        <record id="availability_tennis_tue" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_tennis"/>
            <field name="dayofweek">1</field>
            <field name="hour_from">7.0</field>
            <field name="hour_to">21.0</field>
        </record>
        <record id="availability_tennis_wed" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_tennis"/>
            <field name="dayofweek">2</field>
            <field name="hour_from">7.0</field>
            <field name="hour_to">21.0</field>
        </record>
        <record id="availability_tennis_thu" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_tennis"/>
            <field name="dayofweek">3</field>
            <field name="hour_from">7.0</field>
            <field name="hour_to">21.0</field>
        </record>
        <record id="availability_tennis_fri" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_tennis"/>
            <field name="dayofweek">4</field>
            <field name="hour_from">7.0</field>
            <field name="hour_to">21.0</field>
        </record>
        <record id="availability_tennis_sat" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_tennis"/>
            <field name="dayofweek">5</field>
            <field name="hour_from">8.0</field>
            <field name="hour_to">20.0</field>
        </record>
        <record id="availability_tennis_sun" model="appointment.availability">
            <field name="appointment_type_id" ref="appointment_type_tennis"/>
            <field name="dayofweek">6</field>
            <field name="hour_from">8.0</field>
            <field name="hour_to">18.0</field>
        </record>

        <!-- Product for Expert Consultation -->
        <record id="product_expert_consultation" model="product.product">
            <field name="name">Expert Consultation Service</field>
            <field name="type">service</field>
            <field name="list_price">100.00</field>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="False"/>
            <field name="invoice_policy">order</field>
        </record>

        <!-- Appointment Type: Paid Consultation -->
        <record id="appointment_type_consultation" model="appointment.type">
            <field name="name">Expert Consultation</field>
            <field name="description"><![CDATA[
                <p>Book a one-on-one consultation with an expert.</p>
                <p>Payment is required to confirm your booking.</p>
            ]]></field>
            <field name="slot_duration">1.0</field>
            <field name="slot_interval">1.0</field>
            <field name="max_booking_days">30</field>
            <field name="min_booking_hours">24.0</field>
            <field name="cancel_before_hours">48.0</field>
            <field name="location_type">online</field>
            <field name="assign_staff" eval="True"/>
            <field name="allow_customer_choose_staff" eval="True"/>
            <field name="require_payment" eval="True"/>
            <field name="payment_amount">100.00</field>
            <field name="payment_product_id" ref="product_expert_consultation"/>
            <field name="auto_confirm" eval="True"/>
            <field name="is_published" eval="True"/>
            <field name="icon">fa-user-md</field>
            <field name="staff_user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- FAQ for Consultation -->
        <record id="question_consultation_topic" model="appointment.question">
            <field name="appointment_type_id" ref="appointment_type_consultation"/>
            <field name="name">What topics can I discuss during a consultation?</field>
            <field name="answer"><![CDATA[
                <p>Our expert consultations cover a wide range of topics including:</p>
                <ul>
                    <li>Business strategy and planning</li>
                    <li>Technical architecture reviews</li>
                    <li>Project management guidance</li>
                    <li>Process optimization</li>
                </ul>
                <p>Please describe your specific needs when booking so we can match you with the right expert.</p>
            ]]></field>
            <field name="sequence">1</field>
        </record>

        <record id="question_consultation_experience" model="appointment.question">
            <field name="appointment_type_id" ref="appointment_type_consultation"/>
            <field name="name">How should I prepare for my consultation?</field>
            <field name="answer"><![CDATA[
                <p>To get the most out of your session:</p>
                <ul>
                    <li>Prepare a list of specific questions or topics</li>
                    <li>Gather any relevant documents or data</li>
                    <li>Be ready to share your screen if needed</li>
                </ul>
            ]]></field>
            <field name="sequence">2</field>
        </record>

        <!-- FAQ for Table Booking -->
        <record id="question_table_occasion" model="appointment.question">
            <field name="appointment_type_id" ref="appointment_type_table"/>
            <field name="name">Can I request a special occasion setup?</field>
            <field name="answer"><![CDATA[
                <p>Yes! We offer special arrangements for:</p>
                <ul>
                    <li>Birthdays — complimentary dessert and decoration</li>
                    <li>Anniversaries — romantic table setup with candles</li>
                    <li>Business dinners — presentation-ready private room</li>
                </ul>
                <p>Please mention your occasion in the booking notes.</p>
            ]]></field>
            <field name="sequence">1</field>
        </record>

        <record id="question_table_dietary" model="appointment.question">
            <field name="appointment_type_id" ref="appointment_type_table"/>
            <field name="name">Do you accommodate dietary restrictions?</field>
            <field name="answer"><![CDATA[
                <p>Absolutely! Our kitchen can accommodate:</p>
                <ul>
                    <li>Vegetarian and vegan options</li>
                    <li>Gluten-free dishes</li>
                    <li>Halal preparations</li>
                    <li>Allergy-specific menus</li>
                </ul>
                <p>Please note any dietary needs in the booking notes so we can prepare accordingly.</p>
            ]]></field>
            <field name="sequence">2</field>
        </record>
    </data>
</odoo>
